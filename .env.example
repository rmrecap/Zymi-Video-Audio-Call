# Environment Configuration for ZYMI Ecosystem
# Copy this file to .env and fill in your production values

# ==========================================
# 1. Database Configuration (PostgreSQL)
# ==========================================
POSTGRES_USER=zymi_user
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=zymi_db
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Database URL used by the Node.js Server
DATABASE_URL=postgres://zymi_user:your_secure_postgres_password@postgres:5432/zymi_db

# ==========================================
# 2. Redis Configuration (Socket.io Scaling)
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password

# Complete URL for Server consumption
REDIS_URL=redis://:your_secure_redis_password@redis:6379

# ==========================================
# 3. Server Configuration (Node.js)
# ==========================================
NODE_ENV=production
PORT=5000
JWT_SECRET=your_very_secure_jwt_secret_at_least_64_characters_long
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=zymi-secure-encryption-key-32-chars
CLIENT_ORIGIN=https://your-production-domain.com

# Super Admin Seed (only used if no admin exists)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=your_secure_super_admin_password

# ==========================================
# 4. Client Configuration (React/Vite)
# ==========================================
VITE_API_URL=https://your-production-api-domain.com
VITE_SOCKET_URL=https://your-production-api-domain.com

# ==========================================
# 5. WebRTC Configuration (STUN/TURN)
# ==========================================
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
VITE_TURN_URLS=turn:your.turn.server:3478
VITE_TURN_USERNAME=zymi_turn_user
VITE_TURN_CREDENTIAL=zymi_turn_password

# ==========================================
# 6. Nginx Configuration
# ==========================================
SERVER_NAME=your-production-domain.com
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# ==========================================
# Development Overrides (uncomment for local dev)
# ==========================================
# NODE_ENV=development
# CLIENT_ORIGIN=http://localhost:5175
# VITE_API_URL=http://localhost:5000
# VITE_SOCKET_URL=http://localhost:5000