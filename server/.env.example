# ZYMI Server Configuration
# Copy this file to .env and configure values

# Environment
NODE_ENV=development

# Server
PORT=5000

# Database (PostgreSQL - leave empty to use SQLite)
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://zymi_user:zymi_password@postgres:5432/zymi_db

# Redis (optional - for Socket.io scaling)
# Format: redis://host:port
REDIS_URL=redis://redis:6379

# JWT Authentication
# IMPORTANT: Generate a strong 64-character random secret in production
# Use: openssl rand -hex 32
JWT_SECRET=replace_this_with_64_char_random_secret_in_production
JWT_EXPIRES_IN=7d

# Data Encryption (for credentials at rest)
# Use: openssl rand -hex 16
ENCRYPTION_KEY=zymi-secure-encryption-key-32-chars

# Client Origin (for CORS)
# Must match your client's URL in production
CLIENT_ORIGIN=http://localhost:5175

# Super Admin Seed (only used if no super_admin exists)
# Use a strong password in production
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=your_secure_password_here

# SMTP Settings (Phase 54)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM=noreply@example.com

# TURN Settings (Phase 59/60)
# These are used for administrative reachability tests
ADMIN_TURN_TEST_USER=zymi_admin
ADMIN_TURN_TEST_PASS=zymi_admin_pass